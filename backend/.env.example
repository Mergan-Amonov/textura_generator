# ─────────────────────────────────────────────────────────────
#  PBRForge::Core — Konfiguratsiya namunasi
#  Nusxa oling: cp .env.example .env
#  Keyin .env faylini o'z sozlamalaringizga moslashtiring.
# ─────────────────────────────────────────────────────────────

# ComfyUI ulanish (odatda o'zgartirish shart emas)
COMFYUI_HOST=127.0.0.1
COMFYUI_PORT=8188

# Model nomi — ComfyUI/models/checkpoints/ papkasidagi fayl
# Misol: v1-5-pruned-emaonly.safetensors, dreamshaper_8.safetensors
CHECKPOINT_NAME=v1-5-pruned-emaonly.safetensors

# Generatsiya sozlamalari
DEFAULT_STEPS=25
DEFAULT_CFG=7.0
DEFAULT_SAMPLER=euler_ancestral
DEFAULT_SCHEDULER=karras

# API server
API_HOST=0.0.0.0
API_PORT=8000

# Post-processing
NORMAL_STRENGTH=4.0
ROUGHNESS_GAMMA=1.2
AO_BLUR_RADIUS=4
SEAMLESS_BLEND_PX=64

# Job TTL — tayyor ishlar qancha soniyadan keyin o'chiriladi (3600 = 1 soat)
JOB_TTL=3600
